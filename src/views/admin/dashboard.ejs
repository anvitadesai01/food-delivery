<%- include("../partials/header") %>
<section class="container" style="padding: 40px 0;">
  <h1 style="font-size: 28px; font-weight: 700; margin-bottom: 32px;">⚙️ Admin Dashboard</h1>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px;">
    <a href="/admin/restaurants" style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:32px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);font-weight:600;font-size:15px;color:var(--text-dark);transition:var(--transition);" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:36px;">🍽️</span> Restaurants
    </a>
    <a href="/admin/menu" style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:32px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);font-weight:600;font-size:15px;color:var(--text-dark);transition:var(--transition);" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:36px;">📋</span> Menu
    </a>
    <a href="/admin/orders" style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:32px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);font-weight:600;font-size:15px;color:var(--text-dark);transition:var(--transition);" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:36px;">📦</span> Orders
    </a>
    <a href="/admin/payments" style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:32px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);font-weight:600;font-size:15px;color:var(--text-dark);transition:var(--transition);" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:36px;">💳</span> Payments
    </a>
    <a href="/admin/analytics" style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:32px 20px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);font-weight:600;font-size:15px;color:var(--text-dark);transition:var(--transition);" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
      <span style="font-size:36px;">📊</span> Analytics
    </a>
  </div>
</section>
<%- include("../partials/footer") %>