<%- include("../partials/header") %>

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1>Create Account</h1>
                <p>Join us to order your favorite food</p>
            </div>

            <form class="auth-form" id="registerForm">
                <div class="form-group">
                    <label for="name">👤 Full Name</label>
                    <input type="text" id="name" placeholder="Enter your name" required minlength="2" maxlength="100" />
                </div>

                <div class="form-group">
                    <label for="email">📧 Email Address</label>
                    <input type="email" id="email" placeholder="Enter your email" required />
                </div>

                <div class="form-group">
                    <label for="password">🔐 Password</label>
                    <input type="password" id="password" placeholder="Create a password" required minlength="8" maxlength="30" />
                    <small class="form-helper">Use 8-30 characters with uppercase, lowercase, number, and special character.</small>
                </div>

                <div class="form-group">
                    <label for="confirmPassword">🔒 Confirm Password</label>
                    <input type="password" id="confirmPassword" placeholder="Confirm your password" required minlength="8" maxlength="30" />
                </div>

                <button type="submit" class="btn-primary">
                    Create Account →
                </button>

                <div id="errorMsg" class="error-msg" style="display: none;"></div>
            </form>

            <div class="auth-footer">
                Already have an account? <a href="/login">Sign in</a>
            </div>
        </div>
    </div>
</div>

<%- include("../partials/footer") %>

<script src="/js/auth.js"></script>
