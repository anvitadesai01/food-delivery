<%- include("../partials/header") %>

    <section class="hero">
        <div class="container hero-content">
            <h1>Hungry? <span>Order Food</span><br>From Your Favorite Restaurants</h1>
            <p>Fast delivery • Fresh food • Best prices</p>

            <div class="hero-search">
                <input type="text" id="heroSearchInput" placeholder="Search for restaurants or cuisines..." />
                <button onclick="searchFromHome()" class="hero-search-btn" aria-label="Search">
                    <span>🔍</span>
                </button>
            </div>

            <div class="hero-actions" style="margin-top: 24px;">
                <a href="/restaurants" class="btn-primary">Explore Restaurants →</a>
            </div>
        </div>
    </section>

    <section class="container">
        <div class="quick-filters">
            <div class="filter-pill active" onclick="filterCuisine('')">
                All
            </div>
            <div class="filter-pill" onclick="filterCuisine('Italian')">
                Italian
            </div>
            <div class="filter-pill" onclick="filterCuisine('Indian')">
                Indian
            </div>
            <div class="filter-pill" onclick="filterCuisine('Fast Food')">
                Fast Food
            </div>
            <div class="filter-pill" onclick="filterCuisine('Chinese')">
                Chinese
            </div>
            <div class="filter-pill" onclick="filterCuisine('South Indian')">
                South Indian
            </div>
            <div class="filter-pill" onclick="filterCuisine('Mexican')">
                Mexican
            </div>
        </div>
    </section>

    <section class="restaurants">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">🔥 <span>Top</span> Restaurants Near You</h2>
                <a href="/restaurants" class="view-all">View All →</a>
            </div>
            <div id="restaurants" class="restaurant-grid"></div>
        </div>
    </section>

    <section class="container" style="padding: 40px 0;">
        <div class="section-header">
            <h2 class="section-title">🍜 Popular <span>Dishes</span></h2>
            <a href="/menu" class="view-all">View All →</a>
        </div>
        <div id="dishes" class="restaurant-grid"></div>
    </section>

    <%- include("../partials/footer") %>

        <script src="/js/home.js"></script>
